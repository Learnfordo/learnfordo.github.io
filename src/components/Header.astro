---
import { SITE_TITLE } from '../consts.ts';
const path = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">{SITE_TITLE}</a>
    <div class="nav-tabs" id="nav-tabs">
      <span class="tab-indicator" id="tab-indicator"></span>
      <a href="/" class="nav-tab" class:active={path === '/'}>首页</a>
      <a href="/blog/" class="nav-tab" class:active={path.startsWith('/blog/')}>文章</a>
      <a href="/news/" class="nav-tab" class:active={path.startsWith('/news/')}>AI 快讯</a>
      <a href="/papers/" class="nav-tab" class:active={path.startsWith('/papers/')}>论文库</a>
      <a href="/about/" class="nav-tab" class:active={path.startsWith('/about/')}>关于我</a>
    </div>
    <div class="nav-right">
      <button id="theme-toggle" class="theme-toggle" aria-label="切换主题"></button>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.getElementById('nav-tabs');
    const indicator = document.getElementById('tab-indicator');
    const links = tabs?.querySelectorAll('a.nav-tab');
    if (!tabs || !indicator || !links) return;

    function moveIndicator(el: HTMLElement, instant = false) {
      const rect = el.getBoundingClientRect();
      const parentRect = tabs.getBoundingClientRect();
      const x = rect.left - parentRect.left;

      if (instant) {
        indicator.style.transition = 'none';
      }
      indicator.style.width = rect.width + 'px';
      indicator.style.transform = `translateX(${x}px)`;

      if (instant) {
        indicator.offsetHeight; // force reflow
        indicator.style.transition = '';
      }
    }

    const activeLink = tabs.querySelector('a.active') as HTMLElement;
    if (activeLink) {
      moveIndicator(activeLink, true);
    }

    links.forEach(link => {
      link.addEventListener('mouseenter', () => {
        moveIndicator(link as HTMLElement);
      });
    });

    tabs.addEventListener('mouseleave', () => {
      if (activeLink) moveIndicator(activeLink);
    });
  });
</script>
