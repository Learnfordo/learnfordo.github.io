---
import { SITE_TITLE } from '../consts.ts';
const path = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">{SITE_TITLE}</a>
    <div class="nav-links">
      <a href="/" class:path={path === '/'}>首页</a>
      <a href="/blog/" class:path={path.startsWith('/blog/')}>文章</a>
      <a href="/news/" class:path={path.startsWith('/news/')}>AI 快讯</a>
      <a href="/about/" class:path={path.startsWith('/about/')}>关于我</a>
    </div>
    <div class="nav-right">
      <button id="theme-toggle" class="theme-toggle" aria-label="切换主题"></button>
    </div>
  </div>
</nav>
