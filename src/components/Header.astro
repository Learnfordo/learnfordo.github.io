---
import { SITE_TITLE } from '../consts.ts';
const path = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">{SITE_TITLE}</a>
    <div class="nav-links" id="nav-links">
      <a href="/" class:active={path === '/'}>首页</a>
      <a href="/blog/" class:active={path.startsWith('/blog/')}>文章</a>
      <a href="/news/" class:active={path.startsWith('/news/')}>AI 快讯</a>
      <a href="/papers/" class:active={path.startsWith('/papers/')}>论文库</a>
      <a href="/about/" class:active={path.startsWith('/about/')}>关于我</a>
      <span class="nav-indicator" id="nav-indicator"></span>
    </div>
    <div class="nav-right">
      <button id="theme-toggle" class="theme-toggle" aria-label="切换主题"></button>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navContainer = document.getElementById('nav-links');
    const indicator = document.getElementById('nav-indicator');
    const links = navContainer?.querySelectorAll('a');
    if (!navContainer || !indicator || !links) return;

    function moveIndicator(el: HTMLElement, instant = false) {
      const containerRect = navContainer.getBoundingClientRect();
      const elRect = el.getBoundingClientRect();
      const left = elRect.left - containerRect.left;

      if (instant) {
        indicator.style.transition = 'none';
      }
      indicator.style.width = elRect.width + 'px';
      indicator.style.transform = `translateX(${left}px)`;

      if (instant) {
        // Force reflow then restore transition
        indicator.offsetHeight;
        indicator.style.transition = '';
      }
    }

    // Position on active tab on load
    const activeLink = navContainer.querySelector('a.active') as HTMLElement;
    if (activeLink) {
      moveIndicator(activeLink, true);
    }

    // Animate on hover
    links.forEach(link => {
      link.addEventListener('mouseenter', () => {
        moveIndicator(link as HTMLElement);
      });
    });

    // Reset to active on mouse leave
    navContainer.addEventListener('mouseleave', () => {
      if (activeLink) {
        moveIndicator(activeLink);
      }
    });
  });
</script>
