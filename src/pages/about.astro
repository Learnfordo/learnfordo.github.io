---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const skills = [
  '大模型与 Agent 全技术栈（Transformer → LLM → Agent）',
  'Prompt Engineering / Context Engineering / RAG / Function Call',
  'MCP / Skill 编排与 Agent 框架设计',
  '问答系统、智能客服、多轮对话管理',
  'NLP 意图识别、实体抽取、语义理解',
  'AI 效果评估体系搭建（采纳率、修改率等）',
  'Cursor / Claude Code / OpenClaw Vibe Coding',
];

const experiences = [
  {
    company: '浙报集团-传播大脑科技股份有限公司',
    role: '资深 AI 产品经理',
    period: '2024.07 – 至今',
    items: [
      '主导从零搭建企业级 AI Agent 编排平台，覆盖 5200+ 员工，累计创建 100+ 智能体',
      '建设 AIGC 创作平台，覆盖 3W+ 用户及 1000+ SaaS 企业客户，日均调用 10W+',
      '主导 AI 能力开放平台，200+ 媒体机构接入，统筹模型代理、Skill Hub、Agent 市场',
      '媒资智能检索：Embedding 存储管理，语义/混合/多模态检索能力',
      '潮奔奔 AI 助手：月活 7W+，问题解决率 85%',
    ],
  },
  {
    company: '诺诺网',
    role: '智能应用产品经理',
    period: '2022.02 – 2024.07',
    items: [
      '智能客服准确率由 56% 提升至 88%，人工采纳率达 74%',
      'FAQ 召回排序优化，新增问题推荐、输入联想、自动挖掘知识点',
      '人工客服候选回复预测，结合历史上下文智能推荐',
    ],
  },
  {
    company: '同花顺（校招）',
    role: 'AI 产品经理',
    period: '2019.09 – 2022.02',
    items: [
      '问财智能投顾 — 智能客服机器人：独立负责对话系统，月活约 200W，Query 解决率达 92%',
      '内容安全智能审核：日处理约 100W 审核请求，模型准确率 92%，机审率 90%，节省 10-15 个人工审核人力',
      'AI 训练平台：搭建内网 AI 训练平台，支持文本分类、NER、短文本相似度等 6 大通用模型场景，覆盖公司 90% AI 应用',
    ],
  },
];
---

<BaseLayout>
  <Header />

  <section class="section" style="padding-top: 64px;">
    <div class="wrap">

      <!-- About Hero -->
      <div class="about-hero">
        <div class="about-avatar">
          <img src="/avatar.jpg" alt="高佳强" onerror="this.style.display='none'" />
        </div>
        <div class="about-hero-info">
          <h2>高佳强</h2>
          <div class="role">AI / Agent / 算法 资深产品经理</div>
          <div class="contact">
            gaojiaqiang_china@163.com · 135 8824 0809<br />
            <span class="credential-badge">E类</span><span class="credential-label">杭州市高层次人才</span><br />
            座右铭：细想全是问题，去做全是答案
          </div>
        </div>
      </div>

      <!-- About -->
      <div class="resume-section">
        <h3>关于我</h3>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.8; margin-bottom: 16px;">
          6+ 年 AI 产品经验，专注 LLM 大模型应用与 Agent 平台方向。兼具技术深度与商业落地能力——既理解 Transformer/LLM 底层原理，又能推动产品从 PoC 到规模化变现。
        </p>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.8;">
          教育背景：杭州师范大学 · 电子商务 · 管理学学士（2015.09 – 2019.06）
        </p>
      </div>

      <!-- Skills -->
      <div class="resume-section">
        <h3>核心能力</h3>
        <ul style="list-style: none; padding: 0;">
          {skills.map((s) => (
            <li style="font-size: 14px; color: var(--text-secondary); padding: 6px 0 6px 20px; position: relative; line-height: 1.6;">
              <span style="position: absolute; left: 0; top: 10px; width: 8px; height: 8px; border-radius: 50%; background: var(--accent); opacity: 0.6;"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>

      <!-- Experience -->
      <div class="resume-section">
        <h3>工作经历</h3>
        {experiences.map((exp) => (
          <div class="exp-item">
            <h4>{exp.role}</h4>
            <div class="company">{exp.company}</div>
            <div class="period">{exp.period}</div>
            <ul>
              {exp.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>

      <!-- Links -->
      <div class="resume-section">
        <h3>更多</h3>
        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          <a href="https://github.com/Learnfordo" target="_blank" rel="noopener" class="card" style="padding: 14px 20px; display: inline-block; font-size: 14px; font-weight: 500;">
            GitHub: Learnfordo
          </a>
          <a href="/blog/" class="card" style="padding: 14px 20px; display: inline-block; font-size: 14px; font-weight: 500;">
            研究报告列表 →
          </a>
        </div>
      </div>

    </div>
  </section>

  <Footer />
<style is:global>
.credential-badge {
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--accent);
  background: var(--accent-soft);
  padding: 2px 4px;
  border-radius: 4px;
  letter-spacing: 0.05em;
  line-height: 1.4;
}
.credential-label {
  font-size: 0.75rem;
  color: var(--text-secondary);
  margin-left: 4px;
  line-height: 1.4;
}
</style>
</BaseLayout>
