---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION } from '../consts.ts';
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { join } from 'path';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const recentPosts = sortedPosts.slice(0, 6);

let newsItems: any[] = [];
try {
  const raw = readFileSync(join(process.cwd(), 'src/data/ai-news.json'), 'utf-8');
  newsItems = JSON.parse(raw).items || [];
} catch {
  newsItems = [];
}
---

<BaseLayout>
  <Header />

  <!-- Hero -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-badge">
        <span class="dot"></span>
        <span>AI 产品经理 · 7年经验</span>
      </div>
      <h1 class="hero-title">
        你好，我是
        <span class="rotating-word-wrapper">
          <span class="rotating-word gradient-text active">高佳强</span>
          <span class="rotating-word gradient-text">AI产品经理</span>
          <span class="rotating-word gradient-text">LLM研究者</span>
          <span class="rotating-word gradient-text">Agent实践者</span>
          <span class="rotating-word gradient-text">技术博主</span>
          <span class="rotating-word gradient-text">代码探索者</span>
        </span>
        <svg class="hero-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </h1>
      <p class="subtitle">
        聚焦 LLM 应用与 AI Agent 落地，记录 AI 行业前沿思考与研究报告。
      </p>
    </div>
  </section>

  <!-- AI News -->
  {newsItems.length > 0 && (
  <section class="section">
    <div class="wrap">
      <div class="section-label">AI 快讯</div>
      <h2 class="section-title">今日 AI 动态</h2>
      <p class="section-desc">每日自动抓取 arXiv 与 Hacker News 最新 AI 资讯</p>
      <div class="news-list">
        {newsItems.slice(0, 5).map((item: any) => (
          <div class="news-item">
            <span class="news-date">{item.date}</span>
            <div>
              <h3><a href={item.url || '#'} target="_blank" rel="noopener">{item.title}</a></h3>
              <p>{item.summary}</p>
              {item.tags && item.tags.length > 0 && (
                <div class="news-tags">
                  {item.tags.map((tag: string) => <span class="news-tag">{tag}</span>)}
                </div>
              )}
            </div>
            <span class="news-source">{item.source}</span>
          </div>
        ))}
      </div>
      <p style="margin-top: 20px; text-align: center;">
        <a href="/news/">查看全部 AI 快讯 →</a>
      </p>
    </div>
  </section>
  )}

  <!-- Articles -->
  <section class="section">
    <div class="wrap">
      <div class="section-label">研究报告</div>
      <h2 class="section-title">最新文章</h2>
      <p class="section-desc">深度解读 AI 前沿论文与行业动态</p>
      <div class="articles-grid">
        {recentPosts.map((post) => (
          <a class="article-card" href={`/blog/${post.id}/`}>
            <div class="card">
              <h3>{post.data.title}</h3>
              <p>{post.data.description || (post.excerpt ? post.excerpt.substring(0, 120) : '深度解读 AI 前沿论文与行业动态')}</p>
              <div class="meta">
                <time>{new Date(post.data.pubDate).toLocaleDateString('zh-CN')}</time>
                <span class="read-more">阅读全文 →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
      <p style="margin-top: 24px; text-align: center;">
        <a href="/blog/">查看全部文章 →</a>
      </p>
    </div>
  </section>

  <!-- About teaser -->
  <section class="section">
    <div class="wrap">
      <div class="section-label">关于我</div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px;">
        <div class="card" style="text-align: center; padding: 32px 24px;">
          <div style="font-size: 36px; font-weight: 700;" class="gradient-text">6+年</div>
          <div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">AI 产品经验</div>
        </div>
        <div class="card" style="text-align: center; padding: 32px 24px;">
          <div style="font-size: 36px; font-weight: 700;" class="gradient-text">10+</div>
          <div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">深度研究报告</div>
        </div>
        <div class="card" style="text-align: center; padding: 32px 24px;">
          <div style="font-size: 36px; font-weight: 700;" class="gradient-text">3W+</div>
          <div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">产品覆盖用户</div>
        </div>
      </div>
      <p style="margin-top: 24px; text-align: center;">
        <a href="/about/">了解更多 →</a>
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Rotating word carousel (Claude Code style) */
  .hero-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .rotating-word-wrapper {
    position: relative;
    display: inline-block;
    height: 1.15em;
    overflow: hidden;
    vertical-align: bottom;
    transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .rotating-word {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    text-align: left;
    opacity: 0;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    white-space: nowrap;
    display: inline-block;
  }

  .rotating-word.active {
    opacity: 1;
    transform: translateX(0);
  }

  .rotating-word.exit-left {
    opacity: 0;
    transform: translateX(-100%);
  }

  .hero-arrow {
    width: 40px;
    height: 40px;
    color: var(--accent);
    opacity: 0.6;
    flex-shrink: 0;
    transition: opacity 0.3s;
  }

  .hero-title:hover .hero-arrow {
    opacity: 1;
  }

  @media (max-width: 700px) {
    .hero-title {
      gap: 10px;
      font-size: 28px;
    }
    .hero-arrow {
      width: 28px;
      height: 28px;
    }
    .rotating-word-wrapper {
      height: 1.2em;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.querySelector('.rotating-word-wrapper');
    const words = document.querySelectorAll('.rotating-word');
    if (!wrapper || words.length <= 1) return;

    // Measure each word's natural width and set wrapper to the widest
    function updateWrapperWidth() {
      let maxWidth = 0;
      words.forEach(w => {
        // Temporarily make visible to measure
        const origDisplay = w.style.display;
        const origPosition = w.style.position;
        const origVisibility = w.style.visibility;
        w.style.display = 'inline-block';
        w.style.position = 'static';
        w.style.visibility = 'hidden';
        const width = w.offsetWidth;
        w.style.display = origDisplay;
        w.style.position = origPosition;
        w.style.visibility = origVisibility;
        if (width > maxWidth) maxWidth = width;
      });
      wrapper.style.width = maxWidth + 'px';
    }
    updateWrapperWidth();

    let current = 0;
    const total = words.length;
    const INTERVAL = 2500;

    function rotate() {
      const currentWord = words[current];
      const nextIdx = (current + 1) % total;
      const nextWord = words[nextIdx];

      // Exit current word to the left
      currentWord.classList.remove('active');
      currentWord.classList.add('exit-left');

      // Prepare next word from the right
      nextWord.classList.remove('exit-left');
      nextWord.style.transform = 'translateX(100%)';
      nextWord.style.opacity = '0';

      // Small delay then slide next word in from right
      setTimeout(() => {
        currentWord.classList.remove('exit-left');
        currentWord.style.transform = 'translateX(100%)';
        currentWord.style.opacity = '0';

        nextWord.classList.add('active');
        nextWord.style.transform = '';
        nextWord.style.opacity = '';
        current = nextIdx;
      }, 80);
    }

    setInterval(rotate, INTERVAL);
  });
</script>
