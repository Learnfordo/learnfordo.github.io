---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION } from '../consts.ts';
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { join } from 'path';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const recentPosts = sortedPosts.slice(0, 6);

let newsItems: any[] = [];
try {
  const raw = readFileSync(join(process.cwd(), 'src/data/ai-news.json'), 'utf-8');
  newsItems = JSON.parse(raw).items || [];
} catch {
  newsItems = [];
}
---

<BaseLayout>
  <Header />

  <!-- Hero -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-badge">
        <span class="dot"></span>
        <span>AI 产品经理 · 7年经验</span>
      </div>
      <h1 class="hero-title">
        你好，我是 <span class="typewriter-text gradient-text" id="typewriter-text"></span><span class="typewriter-cursor">|</span>
      </h1>
      <p class="subtitle">
        聚焦 LLM 应用与 AI Agent 落地，记录 AI 行业前沿思考与研究报告。
      </p>
    </div>
  </section>

  <!-- AI News -->
  {newsItems.length > 0 && (
  <section class="section">
    <div class="wrap">
      <div class="section-label">AI 快讯</div>
      <h2 class="section-title">今日 AI 动态</h2>
      <p class="section-desc">每日自动抓取 arXiv 与 Hacker News 最新 AI 资讯</p>
      <div class="news-list">
        {newsItems.slice(0, 5).map((item: any) => (
          <div class="news-item">
            <span class="news-date">{item.date}</span>
            <div>
              <h3><a href={item.url || '#'} target="_blank" rel="noopener">{item.title}</a></h3>
              <p>{item.summary}</p>
              {item.tags && item.tags.length > 0 && (
                <div class="news-tags">
                  {item.tags.map((tag: string) => <span class="news-tag">{tag}</span>)}
                </div>
              )}
            </div>
            <span class="news-source">{item.source}</span>
          </div>
        ))}
      </div>
      <p style="margin-top: 20px; text-align: center;">
        <a href="/news/">查看全部 AI 快讯 →</a>
      </p>
    </div>
  </section>
  )}

  <!-- Articles -->
  <section class="section">
    <div class="wrap">
      <div class="section-label">研究报告</div>
      <h2 class="section-title">最新文章</h2>
      <p class="section-desc">深度解读 AI 前沿论文与行业动态</p>
      <div class="articles-grid">
        {recentPosts.map((post) => (
          <a class="article-card" href={`/blog/${post.id}/`}>
            <div class="card">
              <h3>{post.data.title}</h3>
              <p>{post.data.description || (post.excerpt ? post.excerpt.substring(0, 120) : '深度解读 AI 前沿论文与行业动态')}</p>
              <div class="meta">
                <time>{new Date(post.data.pubDate).toLocaleDateString('zh-CN')}</time>
                <span class="read-more">阅读全文 →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
      <p style="margin-top: 24px; text-align: center;">
        <a href="/blog/">查看全部文章 →</a>
      </p>
    </div>
  </section>

  <!-- About teaser -->
  <section class="section">
    <div class="wrap">
      <div class="section-label">关于我</div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px;">
        <div class="card" style="text-align: center; padding: 32px 24px;">
          <div style="font-size: 36px; font-weight: 700;" class="gradient-text">6+年</div>
          <div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">AI 产品经验</div>
        </div>
        <div class="card" style="text-align: center; padding: 32px 24px;">
          <div style="font-size: 36px; font-weight: 700;" class="gradient-text">10+</div>
          <div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">深度研究报告</div>
        </div>
        <div class="card" style="text-align: center; padding: 32px 24px;">
          <div style="font-size: 36px; font-weight: 700;" class="gradient-text">3W+</div>
          <div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">产品覆盖用户</div>
        </div>
      </div>
      <p style="margin-top: 24px; text-align: center;">
        <a href="/about/">了解更多 →</a>
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Rotating word carousel (Claude Code style) */
  .hero-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .typewriter-text {
    display: inline-block;
    min-width: 2em;
  }

  .typewriter-cursor {
    display: inline-block;
    font-weight: 300;
    color: var(--accent);
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  @media (max-width: 700px) {
    .hero-title {
      gap: 6px;
      font-size: 28px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('typewriter-text');
    if (!el) return;

    const wordList = ['高佳强', 'AI产品经理', 'LLM研究者', 'Agent实践者', '技术博主', '代码探索者'];
    const TYPE_SPEED = 120;   // ms per character (typing)
    const DELETE_SPEED = 80;  // ms per character (deleting)
    const PAUSE_AFTER = 1800; // pause after full word
    const PAUSE_BEFORE = 400; // pause before next word

    let wordIdx = 0;
    let charIdx = 0;
    let isDeleting = false;

    function tick() {
      const word = wordList[wordIdx];

      if (!isDeleting) {
        // Typing
        charIdx++;
        el.textContent = word.substring(0, charIdx);
        if (charIdx === word.length) {
          isDeleting = true;
          setTimeout(tick, PAUSE_AFTER);
          return;
        }
        setTimeout(tick, TYPE_SPEED);
      } else {
        // Deleting
        charIdx--;
        el.textContent = word.substring(0, charIdx);
        if (charIdx === 0) {
          isDeleting = false;
          wordIdx = (wordIdx + 1) % wordList.length;
          setTimeout(tick, PAUSE_BEFORE);
          return;
        }
        setTimeout(tick, DELETE_SPEED);
      }
    }

    // Start after a short delay
    setTimeout(tick, 600);
  });
</script>
