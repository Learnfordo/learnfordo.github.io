---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const rawData = await import('../../data/papers.json');
const allPapers = (rawData?.default || rawData || []);
const sorted = [...allPapers].sort((a, b) => (b.date || '').localeCompare(a.date || ''));
const vendors = [...new Set(sorted.map(p => p.vendor).filter(Boolean))];

---

<BaseLayout>
  <Header />

  <section class="section" style="padding-top: 64px; padding-bottom: 80px;">
    <div class="wrap">
      <h1 style="font-size: 32px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px;">论文库</h1>
      <p style="font-size: 15px; color: var(--text-secondary); margin-bottom: 36px;">Top 15 AI 厂商发布的新模型论文，每日自动更新 · 论文 PDF 可直接预览/下载</p>

      <!-- 厂商筛选 -->
      <div id="vendor-filters" style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; align-items: center;">
        <button class="v-filter active" data-vendor="all"
          style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 24px; border: 1.5px solid var(--accent); background: var(--accent); color: #fff; font-size: 13px; cursor: pointer; transition: all 0.2s; font-weight: 600;"
        >全部（{sorted.length}）</button>
        {vendors.map(v => (
          <button class="v-filter" data-vendor={v}
            style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 14px; border-radius: 24px; border: 1.5px solid var(--border); background: var(--bg-card); color: var(--text-secondary); font-size: 12px; cursor: pointer; transition: all 0.2s;"
          >
            {v}（{sorted.filter(p => p.vendor === v).length}）
          </button>
        ))}
      </div>

      <!-- 论文列表 -->
      <div id="papers-list">
        {sorted.map((paper) => (
          <div class="paper-card" data-vendor={paper.vendor || ''}
            style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; margin-bottom: 12px; transition: all 0.2s;"
          >
            <div style="display: flex; gap: 14px; align-items: flex-start;">
              <div style="flex:1; min-width:0;">
                <div class="paper-meta" style="display:flex; align-items:center; gap:8px; margin-bottom:5px; flex-wrap:wrap;">
                  <span class="vendor-badge" style="font-size:11px; color:var(--accent); background:var(--accent-soft); padding:1px 9px; border-radius:10px; font-weight:600;">{paper.vendor}</span>
                  <span style="font-size:11px; color:var(--text-muted);">{paper.date}</span>
                  {paper.arxivId && <span style="font-size:10px; color:var(--text-muted);">arXiv:{paper.arxivId.replace(/v\d+$/,'')}</span>}
                  {paper.tags?.includes('HuggingFace') && <span style="font-size:10px; color:#ff9d00; background:#fff3e0; padding:1px 7px; border-radius:8px;">🤗 HF</span>}
                </div>
                <h3 style="font-size:15px; font-weight:600; margin-bottom:6px; line-height:1.55; color:var(--text-primary);">
                  {paper.title}
                </h3>
                <p style="font-size:13px; color:var(--text-secondary); line-height:1.7;">
                  {paper.descriptionCn || paper.summary?.substring(0,200) || '暂无简介'}
                </p>
              </div>
              {paper.pdfUrl && (
                <a href={paper.pdfUrl} target="_blank" rel="noopener noreferrer" title="查看 PDF"
                  class="pdf-btn"
                  style="flex-shrink:0; font-size:12px; color:var(--accent); border:1.5px solid var(--accent); padding:7px 16px; border-radius:8px; text-decoration:none; font-weight:600; white-space:nowrap; transition:all 0.2s;"
                >📄 PDF</a>
              )}
            </div>
          </div>
        ))}
      </div>

      {sorted.length === 0 && (
        <p style="font-size: 14px; color: var(--text-secondary); text-align: center; padding: 48px 0;">暂无论文数据，等待自动抓取...</p>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  const btns = document.querySelectorAll('.v-filter');
  const cards = document.querySelectorAll('.paper-card');
  btns.forEach(b => {
    b.addEventListener('click', () => {
      const vendor = b.dataset.vendor;
      btns.forEach(x => {
        if (x.dataset.vendor === vendor) {
          x.style.background = 'var(--accent)';
          x.style.color = '#fff';
          x.style.borderColor = 'var(--accent)';
        } else {
          x.style.background = 'var(--bg-card)';
          x.style.color = 'var(--text-secondary)';
          x.style.borderColor = 'var(--border)';
        }
      });
      cards.forEach(c => {
        c.style.display = (vendor === 'all' || c.dataset.vendor === vendor) ? '' : 'none';
      });
    });
  });
</script>

<style is:global>
  .v-filter:hover { border-color: var(--accent) !important; }
  .paper-card:hover { border-color: var(--accent); box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  .pdf-btn:hover { background: var(--accent) !important; color: #fff !important; }
</style>