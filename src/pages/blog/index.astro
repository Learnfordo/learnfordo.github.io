---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout>
  <Header />

  <section class="section" style="padding-top: 64px;">
    <div class="wrap">
      <div class="section-label">研究报告</div>
      <h1 style="font-size: 32px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px;">全部文章</h1>
      <p style="font-size: 15px; color: var(--text-secondary); margin-bottom: 36px;">
        深度解读 AI 前沿论文与行业动态，持续更新
      </p>

      <div class="blog-list">
        {sortedPosts.map((post) => (
          <div class="blog-list-item">
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            <time>{new Date(post.data.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}</time>
          </div>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div style="text-align: center; padding: 60px 0; color: var(--text-muted);">
          <p>文章持续更新中，敬请期待...</p>
        </div>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>
